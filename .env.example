TELEGRAM_BOT_TOKEN=
OPENAI_API_KEY=
DATABASE_PATH=./data/nila.sqlite
NODE_ENV=development
# GlitchTip DSN — Project Settings → Client Keys (DSN) в app.glitchtip.com.
# Пусто = трекинг ошибок отключён (graceful degradation).
GLITCHTIP_DSN=
# Bearer-токен для internal-дашборда (src/transport/dashboardApi.ts) — придумать случайную строку.
DASHBOARD_TOKEN=
DASHBOARD_PORT=3001
DASHBOARD_STATIC_DIR=./dashboard/dist
# Comma-separated Telegram userId'ы для ручного QA живого интервью — эти
# пользователи проходят интервью любыми ответами (движок-заглушка вместо
# OpenAI, см. infrastructure/testing/testModeInterviewEngine.ts). Пусто по
# умолчанию — обычные пользователи не затронуты.
INTERVIEW_TEST_MODE_USER_IDS=
# Только для scripts/sttGoldenBenchmark.ts (pnpm run stt:benchmark) — генерация
# golden-аудио независимым TTS-вендором. Не нужен основному процессу, поэтому
# не в src/config/env.ts. Пусто = скрипт откажется запускаться с понятной ошибкой.
ELEVENLABS_API_KEY=

# Только для scripts/syncCourses.ts (pnpm run courses:sync) — New Mind Start
# course catalog API. Не в src/config/env.ts — не нужен основному процессу,
# пока не подключён проактивный советник (docs/sprint-plan.md, Sprint 4).
NMS_API_URL=https://newmindstart.com
NMS_BOT_KEY=
# NILA_SERVER_TOKEN=  # альтернатива NMS_BOT_KEY, если когда-нибудь заведут отдельный токен
